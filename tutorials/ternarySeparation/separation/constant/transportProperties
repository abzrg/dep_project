FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

transportModel  Newtonian;

// Fluid/Medium density
rhoInf          1000;     // [kg/m^3]

// Fluid/Medium kinematic viscosity
nu              1e-06;    // [m^2/s]


